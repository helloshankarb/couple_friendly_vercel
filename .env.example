# Vercel Environment Variables — Couple Friendly API
# Set these in Vercel Dashboard → Project → Settings → Environment Variables
# NEVER commit real values to git

GEMINI_KEY=your_gemini_api_key_here
GROQ_KEY_1=your_groq_key_1_here
GROQ_KEY_2=your_groq_key_2_here
GROQ_KEY_3=your_groq_key_3_here
GROQ_KEY_4=your_groq_key_4_here

# Optional: shared secret the Android app sends as X-App-Secret header
# Prevents random people from calling your endpoint
APP_SECRET=your_random_secret_here
